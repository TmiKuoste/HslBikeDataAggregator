{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "4728501537445535075"
    }
  },
  "parameters": {
    "environmentName": {
      "type": "string",
      "allowedValues": [
        "dev",
        "prod"
      ],
      "metadata": {
        "description": "Deployment environment name."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for the deployment."
      }
    },
    "functionAppName": {
      "type": "string",
      "minLength": 2,
      "metadata": {
        "description": "Globally unique Azure Function App name."
      }
    },
    "corsAllowedOrigin": {
      "type": "string",
      "defaultValue": "https://kuoste.github.io",
      "metadata": {
        "description": "Frontend origin allowed by Azure Functions CORS configuration."
      }
    },
    "pollIntervalCron": {
      "type": "string",
      "defaultValue": "0 */5 * * * *",
      "metadata": {
        "description": "Cron expression used by the PollStations timer trigger."
      }
    },
    "snapshotHistoryLimit": {
      "type": "int",
      "defaultValue": 60,
      "minValue": 1,
      "metadata": {
        "description": "Number of snapshots retained in blob storage."
      }
    }
  },
  "variables": {
    "appServicePlanName": "[format('{0}-plan', parameters('functionAppName'))]",
    "applicationInsightsName": "[format('{0}-appi', parameters('functionAppName'))]",
    "storageAccountName": "[take(format('st{0}{1}', toLower(replace(replace(parameters('functionAppName'), '-', ''), '_', '')), uniqueString(resourceGroup().id)), 24)]",
    "contentShareName": "[take(toLower(format('{0}{1}', replace(replace(parameters('functionAppName'), '-', ''), '_', ''), uniqueString(parameters('functionAppName')))), 63)]"
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[variables('storageAccountName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard_LRS"
      },
      "kind": "StorageV2",
      "properties": {
        "accessTier": "Hot",
        "allowBlobPublicAccess": false,
        "allowSharedKeyAccess": true,
        "minimumTlsVersion": "TLS1_2",
        "supportsHttpsTrafficOnly": true
      },
      "tags": {
        "azd-env-name": "[parameters('environmentName')]",
        "environment": "[parameters('environmentName')]",
        "project": "HslBikeDataAggregator"
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[variables('applicationInsightsName')]",
      "location": "[parameters('location')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web",
        "Flow_Type": "Bluefield",
        "Request_Source": "rest"
      },
      "tags": {
        "azd-env-name": "[parameters('environmentName')]",
        "environment": "[parameters('environmentName')]",
        "project": "HslBikeDataAggregator"
      }
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-12-01",
      "name": "[variables('appServicePlanName')]",
      "location": "[parameters('location')]",
      "kind": "functionapp",
      "sku": {
        "name": "Y1",
        "tier": "Dynamic"
      },
      "properties": {
        "reserved": false
      },
      "tags": {
        "azd-env-name": "[parameters('environmentName')]",
        "environment": "[parameters('environmentName')]",
        "project": "HslBikeDataAggregator"
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[parameters('functionAppName')]",
      "location": "[parameters('location')]",
      "kind": "functionapp",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
        "httpsOnly": true,
        "clientAffinityEnabled": false,
        "siteConfig": {
          "alwaysOn": false,
          "appSettings": [
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[reference(resourceId('Microsoft.Insights/components', variables('applicationInsightsName')), '2020-02-02').ConnectionString]"
            },
            {
              "name": "AzureWebJobsStorage",
              "value": "[format('DefaultEndpointsProtocol=https;AccountName={0};EndpointSuffix={1};AccountKey={2}', variables('storageAccountName'), environment().suffixes.storage, listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2023-05-01').keys[0].value)]"
            },
            {
              "name": "FUNCTIONS_EXTENSION_VERSION",
              "value": "~4"
            },
            {
              "name": "FUNCTIONS_WORKER_RUNTIME",
              "value": "dotnet-isolated"
            },
            {
              "name": "PollIntervalCron",
              "value": "[parameters('pollIntervalCron')]"
            },
            {
              "name": "SnapshotHistoryLimit",
              "value": "[string(parameters('snapshotHistoryLimit'))]"
            },
            {
              "name": "WEBSITE_CONTENTAZUREFILECONNECTIONSTRING",
              "value": "[format('DefaultEndpointsProtocol=https;AccountName={0};EndpointSuffix={1};AccountKey={2}', variables('storageAccountName'), environment().suffixes.storage, listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2023-05-01').keys[0].value)]"
            },
            {
              "name": "WEBSITE_CONTENTSHARE",
              "value": "[variables('contentShareName')]"
            },
            {
              "name": "WEBSITE_RUN_FROM_PACKAGE",
              "value": "1"
            }
          ],
          "cors": {
            "allowedOrigins": [
              "[parameters('corsAllowedOrigin')]"
            ],
            "supportCredentials": false
          },
          "ftpsState": "Disabled",
          "http20Enabled": true,
          "minTlsVersion": "1.2"
        }
      },
      "tags": {
        "azd-env-name": "[parameters('environmentName')]",
        "environment": "[parameters('environmentName')]",
        "project": "HslBikeDataAggregator"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/components', variables('applicationInsightsName'))]",
        "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
      ]
    }
  ],
  "outputs": {
    "functionAppName": {
      "type": "string",
      "value": "[parameters('functionAppName')]"
    },
    "functionHostname": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2023-12-01').defaultHostName)]"
    },
    "storageAccountName": {
      "type": "string",
      "value": "[variables('storageAccountName')]"
    },
    "applicationInsightsName": {
      "type": "string",
      "value": "[variables('applicationInsightsName')]"
    },
    "managedIdentityPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2023-12-01', 'full').identity.principalId]"
    }
  }
}